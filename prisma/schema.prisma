generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(uuid())
  lineUserId           String            @unique @map("line_user_id")
  lineDisplayName      String            @map("line_display_name")
  linePictureUrl       String?           @map("line_picture_url")
  lineEmail            String?           @map("line_email")
  lineFollowedOAAt     DateTime?         @map("line_followed_oa_at")
  email                String?           @unique
  fullName             String?           @map("full_name")
  avatarUrl            String?           @map("avatar_url")
  onboardingStep       String            @default("line_login") @map("onboarding_step")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  acceptedTermsAt      DateTime?         @map("accepted_terms_at")
  acceptedTermsVersion String?           @map("accepted_terms_version")
  auditLogs            AuditLog[]
  googleConnection     GoogleConnection?
  lineConnection       LineConnection?
  invitesSent          OrgMember[]       @relation("InvitedBy")
  orgMembers           OrgMember[]
  ownedOrgs            Organization[]    @relation("OrgOwner")
  permissions          UserPermission[]
  affiliatePartner     AffiliatePartner?

  @@map("users")
}

model LineConnection {
  id            String    @id @default(uuid())
  userId        String    @unique @map("user_id")
  accessToken   String    @map("access_token")
  refreshToken  String?   @map("refresh_token")
  tokenExpiry   DateTime? @map("token_expiry")
  scopes        String[]  @default([])
  isFollowingOA Boolean   @default(false) @map("is_following_oa")
  oaLinkedAt    DateTime? @map("oa_linked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("line_connections")
}

model GoogleConnection {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  googleEmail  String    @map("google_email")
  accessToken  String    @map("access_token")
  refreshToken String    @map("refresh_token")
  tokenExpiry  DateTime? @map("token_expiry")
  scopes       String[]  @default([])
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_connections")
}

model Organization {
  id                     String           @id @default(uuid())
  name                   String
  slug                   String           @unique
  ownerId                String           @map("owner_id")
  taxId                  String           @map("tax_id")
  address                String
  phone                  String?
  logoUrl                String?          @map("logo_url")
  googleSpreadsheetId    String?          @map("google_spreadsheet_id")
  googleDriveFolderId    String?          @map("google_drive_folder_id")
  driveReceiptsFolderId  String?          @map("drive_receipts_folder_id")
  driveDocumentsFolderId String?          @map("drive_documents_folder_id")
  driveReportsFolderId   String?          @map("drive_reports_folder_id")
  settings               Json             @default("{}")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  branchNumber           String           @default("00000") @map("branch_number")
  branchType             String           @default("HQ") @map("branch_type")
  auditLogs              AuditLog[]
  invitations            Invitation[]
  members                OrgMember[]
  owner                  User             @relation("OrgOwner", fields: [ownerId], references: [id])
  subscription           Subscription?
  permissions            UserPermission[]

  @@map("organizations")
}

model OrgMember {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  userId      String       @map("user_id")
  role        String       @default("staff")
  status      String       @default("pending")
  invitedById String?      @map("invited_by")
  joinedAt    DateTime?    @map("joined_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  eventScope  String[]     @default([]) @map("event_scope")
  invitedBy   User?        @relation("InvitedBy", fields: [invitedById], references: [id])
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model Invitation {
  id               String       @id @default(uuid())
  orgId            String       @map("org_id")
  token            String       @unique
  displayName      String       @map("display_name")
  role             String       @default("staff")
  eventScope       String[]     @default([]) @map("event_scope")
  permissions      Json?
  status           String       @default("pending")
  expiresAt        DateTime     @map("expires_at")
  acceptedAt       DateTime?    @map("accepted_at")
  acceptedByUserId String?      @map("accepted_by_user_id")
  invitedById      String       @map("invited_by")
  createdAt        DateTime     @default(now()) @map("created_at")
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([orgId, status])
  @@map("invitations")
}

model UserPermission {
  id                       String       @id @default(uuid())
  orgId                    String       @map("org_id")
  userId                   String       @map("user_id")
  manageEvents             Boolean      @default(false) @map("manage_events")
  assignEvents             Boolean      @default(false) @map("assign_events")
  managePayees             Boolean      @default(false) @map("manage_payees")
  manageBanks              Boolean      @default(false) @map("manage_banks")
  updatePayments           Boolean      @default(false) @map("update_payments")
  deletePayments           Boolean      @default(false) @map("delete_payments")
  approvePayments          Boolean      @default(false) @map("approve_payments")
  viewReports              Boolean      @default(false) @map("view_reports")
  printReports             Boolean      @default(false) @map("print_reports")
  dashboardEvent           Boolean      @default(false) @map("dashboard_event")
  dashboardSummary         Boolean      @default(false) @map("dashboard_summary")
  manageUsers              Boolean      @default(false) @map("manage_users")
  managePermissions        Boolean      @default(false) @map("manage_permissions")
  isCustom                 Boolean      @default(false) @map("is_custom")
  updatedAt                DateTime     @updatedAt @map("updated_at")
  editPaymentAfterApproval Boolean      @default(false) @map("edit_payment_after_approval")
  // ===== S24: Revenue module =====
  manageCustomers          Boolean      @default(false) @map("manage_customers")
  manageQuotations         Boolean      @default(false) @map("manage_quotations")
  manageBillings           Boolean      @default(false) @map("manage_billings")
  manageTaxInvoices        Boolean      @default(false) @map("manage_tax_invoices")
  org                      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("user_permissions")
}

model Subscription {
  id                   String       @id @default(uuid())
  orgId                String       @unique @map("org_id")
  plan                 String       @default("free")
  status               String       @default("active")
  // === Trial (S26) — overrides plan if trialEndsAt > now ===
  trialPlan            String?      @map("trial_plan")
  trialStartedAt       DateTime?    @map("trial_started_at")
  trialEndsAt          DateTime?    @map("trial_ends_at")
  // === Stripe billing state (S26) ===
  stripeCustomerId     String?      @map("stripe_customer_id")
  stripeSubscriptionId String?      @map("stripe_subscription_id")
  stripePriceId        String?      @map("stripe_price_id")
  billingInterval      String?      @map("billing_interval") // "monthly" | "yearly"
  currentPeriodEnd     DateTime?    @map("current_period_end")
  cancelAtPeriodEnd    Boolean      @default(false) @map("cancel_at_period_end")
  // === Beta flag — manual extend / free Pro for closed-beta testers ===
  isBetaTester         Boolean      @default(false) @map("is_beta_tester")
  // === Quotas (cached from PLAN_LIMITS for fast read; refreshed on plan change) ===
  maxMembers           Int          @default(2) @map("max_members")
  maxEvents            Int          @default(3) @map("max_events")
  scanCredits          Int          @default(8) @map("scan_credits")
  creditsUsed          Int          @default(0) @map("credits_used")
  bonusCredits         Int          @default(0) @map("bonus_credits")
  billingPeriodStart   DateTime?    @map("billing_period_start")
  billingPeriodEnd     DateTime?    @map("billing_period_end")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// Per-org per-month usage counter for quota enforcement (OCR, future API calls, etc.).
model UsageCounter {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  yearMonth String   @map("year_month") // "2026-05"
  metric    String // "ocr" — extend as needed
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([orgId, yearMonth, metric])
  @@map("usage_counters")
}

/// Affiliate / referral partner that distributes a code.
/// `programType` differentiates customer-referral (mutual free month) from
/// partner-affiliate (cash payout).
model AffiliatePartner {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  code            String       @unique
  programType     String       @default("customer_referral") @map("program_type")
  isActive        Boolean      @default(true) @map("is_active")
  payoutMethod    String?      @map("payout_method") // "promptpay" | "stripe_connect"
  payoutAccount   String?      @map("payout_account")
  totalReferrals  Int          @default(0) @map("total_referrals")
  totalCommission Decimal      @default(0) @db.Decimal(12, 2) @map("total_commission")
  createdAt       DateTime     @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals   Referral[]
  commissions Commission[]

  @@map("affiliate_partners")
}

/// One referral = one signup that successfully applied a partner code.
/// Status lifecycle: pending → confirmed (after first paid invoice) → refunded if reversed.
model Referral {
  id              String    @id @default(uuid())
  partnerId       String    @map("partner_id")
  referredOrgId   String    @unique @map("referred_org_id")
  code            String
  status          String    @default("pending") // pending | confirmed | refunded | invalid
  signedUpAt      DateTime  @default(now()) @map("signed_up_at")
  firstPaymentAt  DateTime? @map("first_payment_at")
  confirmedAt     DateTime? @map("confirmed_at")
  discountApplied String    @default("20pct_first_month_plus_100ocr") @map("discount_applied")

  partner     AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  commissions Commission[]

  @@map("referrals")
}

/// One commission entry = one scheduled payout for one month of a confirmed referral.
/// Pay-after-month-2: monthIndex 1 has 0%, then 40/25/15 declining.
model Commission {
  id            String    @id @default(uuid())
  partnerId     String    @map("partner_id")
  referralId    String    @map("referral_id")
  monthIndex    Int       @map("month_index")
  amountTHB     Decimal   @db.Decimal(10, 2) @map("amount_thb")
  status        String    @default("scheduled") // scheduled | paid | held | clawed_back
  scheduledFor  DateTime  @map("scheduled_for")
  paidAt        DateTime? @map("paid_at")
  payoutBatchId String?   @map("payout_batch_id")

  partner  AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referral Referral         @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@map("commissions")
}

model AuditLog {
  id         String       @id @default(uuid())
  orgId      String       @map("org_id")
  userId     String       @map("user_id")
  action     String
  entityType String       @map("entity_type")
  entityRef  String?      @map("entity_ref")
  summary    String?
  createdAt  DateTime     @default(now()) @map("created_at")
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, entityType, entityRef])
  @@map("audit_logs")
}

model LineDraft {
  id             String   @id @default(uuid())
  lineUserId     String   @map("line_user_id")
  userId         String   @map("user_id")
  orgId          String   @map("org_id")
  imageMessageId String   @map("image_message_id")
  ocrJson        Json     @map("ocr_json")
  driveFileId    String?  @map("drive_file_id")
  driveFileUrl   String?  @map("drive_file_url")
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")
  mimeType       String   @default("image/jpeg") @map("mime_type")
  eventId        String?  @map("event_id")
  eventName      String?  @map("event_name")

  @@index([lineUserId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@map("line_drafts")
}
