.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ----- Misc -----
*.pem
.cache/
.tmp/
tmp/

# ----- Prisma -----
# keep schema.prisma in repo, ignore generated client
# (postinstall script generates it fresh)

# ----- Project-specific -----
