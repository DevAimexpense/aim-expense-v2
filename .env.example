# ===========================================
# Aim Expense V2 — Environment Variables Template
# Copy to .env.local และใส่ค่าจริง (อย่า commit .env.local!)
# สำหรับ Vercel — ใส่ค่าพวกนี้ใน Project Settings → Environment Variables
# ===========================================

# ----- App Base URL (สำคัญตอน deploy!) -----
# Local: http://localhost:3000
# Production: https://<your-vercel-domain>.vercel.app หรือ custom domain
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ----- Supabase (Server DB: users, orgs, subs, permissions) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Database (Prisma → Supabase PostgreSQL Pooler) -----
# ใช้ connection pooler URL (port 5432) ใน production
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ----- Google OAuth (Login + Sheets/Drive access) -----
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# Production: https://<your-domain>/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ----- NextAuth -----
# Generate random 32+ char: openssl rand -base64 32
NEXTAUTH_SECRET=generate-random-secret-here

# ----- LINE Login (Identity Provider) -----
LINE_LOGIN_CHANNEL_ID=2009xxxxxx
LINE_LOGIN_CHANNEL_SECRET=xxx
# Production: https://<your-domain>/api/auth/line/callback
LINE_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

# ----- LINE Messaging API (OA: Notifications + Receipt receiving) -----
LINE_MESSAGING_CHANNEL_ID=2009xxxxxx
LINE_MESSAGING_CHANNEL_SECRET=xxx
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=xxx
LINE_OA_BASIC_ID=@your-oa-id

# ----- Stripe (Phase 6 — ยังไม่ต้องใส่ตอนนี้) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----- OCR Engines -----
# Primary: AksonOCR (Thai-specialized, free 100/day)
AKSONOCR_API_KEY=your-akson-key

# Fallback: OpenAI GPT-4o Vision
OPENAI_API_KEY=sk-xxx
OPENAI_OCR_MODEL=gpt-4o

# ----- Encryption (สำหรับเก็บ Google OAuth tokens ใน DB) -----
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=64-char-hex-string-here
